# Copy this file to .env.local and fill in your key. NEVER commit .env.local.
# The key is read ONLY server-side (app/api/judge/route.ts). It is never sent to the client.
OPENAI_API_KEY=

# Optional model overrides. Defaults are locked in lib/engine/config.ts.
# SENTINEL_JUDGE_MODEL=gpt-5.4
# SENTINEL_SUMMARY_MODEL=gpt-5.4-mini

# ElevenLabs key for the guided demo voice (optional — falls back to text)
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
